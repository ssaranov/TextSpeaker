@model List<TextToSpeech.Models.SpeechLog>
@{
	ViewData["Title"] = "Админка логов";
}

<div class="container mt5-">
	<h1 class="mb-4">MVC Админка Логи озвучки</h1>
	@if(Model.Count ==0)
	{
		<div class="alert alert info">
			Логов пока нету
		</div>
	}
	else{
		<table class="table-bordered tabel-hover align-middle">
			<thead class="table-dark">
				<tr>
					<th>Пользователь</th>
					<th>Текст</th>
					<th>Голос</th>
					<th>Скорость</th>
					<th>Дата</th>
				</tr>
			</thead>
			<tbody>
				@foreach(var log in Model)
				{
				<tr>
					<td>@log.User?.Name</td>
					<td style="max-width:400px">@log.Text</td>
					<td>@log.VoiceName</td>
					<td>@log.Rate</td>
					<td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
				</tr>
				}
			</tbody>
		</table>
	}
</div>